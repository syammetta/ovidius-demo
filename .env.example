ANTHROPIC_API_KEY=your-anthropic-api-key
VOYAGE_API_KEY=your-voyage-api-key
DATABASE_URL=postgresql://user:password@localhost:5432/ovidius

# Cloudflare R2 — raw document storage / crawl cache
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=ovidius-docs

EMBEDDING_MODEL=voyage-3
EMBEDDING_DIMENSION=1024
GENERATION_MODEL=claude-sonnet-4-6
# Reranking uses FlashRank (local cross-encoder, no API key needed)
# Corrective RAG + contextualization use Claude Haiku via ANTHROPIC_API_KEY

# Demo access gate for dashboard landing page
DEMO_ACCESS_CODE=OVIDIUS-DEMO-2026

# Optional Redis (queue acceleration + cache)
REDIS_URL=redis://localhost:6379/0

# For production split (web + worker), set false on web service
# and run worker process separately: python -m scripts.ingest_worker
INGESTION_INLINE_WORKER=true
INGESTION_STALE_AFTER_SECONDS=180

CHUNK_SIZE=600
CHUNK_OVERLAP=100
RETRIEVAL_TOP_N=20
RERANK_TOP_K=5
